POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_DB=care
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@db:5432/care
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0

DJANGO_DEBUG=true
ATTACH_DEBUGGER=false

BUCKET_REGION=ap-south-1
BUCKET_KEY=${MINIO_ACCESS_KEY:-minioadmin}
BUCKET_SECRET=${MINIO_SECRET_KEY:-minioadmin}
BUCKET_ENDPOINT=http://minio:9000
BUCKET_EXTERNAL_ENDPOINT=http://localhost:9100
FILE_UPLOAD_BUCKET=patient-bucket
FACILITY_S3_BUCKET=facility-bucket

# ============================================================================
# Odoo ERP Integration
# ============================================================================
# Connects to Odoo 19.0 instance running at the configured host:port
CARE_ODOO_HOST=odoo
CARE_ODOO_PORT=8069
CARE_ODOO_PROTOCOL=http
CARE_ODOO_DATABASE=care
CARE_ODOO_USERNAME=admin
CARE_ODOO_PASSWORD=admin
