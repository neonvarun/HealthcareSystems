<odoo>
    <record id="discount_excel_wizard_view" model="ir.ui.view">
        <field name="name">discount.categ.wizard.form</field>
        <field name="model">discount.categ.wizard</field>
        <field name="arch" type="xml">
            <form string="Discount Excel Report">
                <group col="4">
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button name="action_disc_export_excel" string="Print Excel" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_discount_excel_wizard" model="ir.actions.act_window">
        <field name="name">Discount Report</field>
        <field name="res_model">discount.categ.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="discount_excel_wizard_view"/>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_discount_excel_report"
              name="Discount Report"
              parent="invoice_reports.menu_nvoice_report_menu"
              sequence="20"
              action="action_discount_excel_wizard"/>
</odoo>
