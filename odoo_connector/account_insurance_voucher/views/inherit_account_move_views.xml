<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_insurance_bill" model="ir.actions.report">
        <field name="name">Print Insurance Voucher</field>
        <field name="model">customer.insurance</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account_insurance_voucher.report_invoice_custom_bill</field>
        <field name="report_file">account_insurance_voucher.report_invoice_custom_bill</field>
    </record>

    <record id="action_print_insurance_voucher" model="ir.actions.server">
        <field name="name">Print Insurance Voucher</field>
        <field name="model_id" ref="model_customer_insurance"/>
        <field name="binding_model_id" ref="model_customer_insurance"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
            action = records.print_insurance_voucher()
        </field>
    </record>

</odoo>