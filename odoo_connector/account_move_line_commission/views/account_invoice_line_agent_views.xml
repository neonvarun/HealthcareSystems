<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_invoice_line_agent_list" model="ir.ui.view">
        <field name="name">account.invoice.line.agent.list</field>
        <field name="model">account.invoice.line.agent</field>
        <field name="arch" type="xml">
            <list string="Commission Lines">
                <field name="agent_id"/>
                <field name="commission_id"/>
                <field name="invoice_id"/>
                <field name="invoice_date"/>
                <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id"/>
                <field name="commission_state"/>
            </list>
        </field>
    </record>

    <record id="action_account_invoice_line_agent" model="ir.actions.act_window">
        <field name="name">Commission Lines</field>
        <field name="res_model">account.invoice.line.agent</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_account_invoice_line_agent_list"/>
    </record>

    <menuitem id="menu_commission_lines_root"
              name="Commission Lines"
              parent="account_commission_oca.menu_invoicing_commission"
              action="action_account_invoice_line_agent"
              sequence="30"/>

</odoo>
