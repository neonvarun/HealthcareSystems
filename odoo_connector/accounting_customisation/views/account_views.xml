<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Journal: Add tax journal flags -->
    <record id="view_account_journal_form_inherit" model="ir.ui.view">
        <field name="name">account.journal.form.inherit.tax</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='advanced_settings']/group" position="inside">
                <group string="Sales Invoice Auto-Selection" invisible="type != 'sale'">
                    <field name="is_taxed_journal"/>
                    <field name="is_untaxed_journal"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
