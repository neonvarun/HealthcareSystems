<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit journal form to add care fields and enforce required on inbound payment method lines -->
    <record id="view_account_journal_form_care_inbound" model="ir.ui.view">
        <field name="name">account.journal.form.care.inbound</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='inbound_payment_method_line_ids']//list//field[@name='name']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//field[@name='inbound_payment_method_line_ids']//list//field[@name='payment_account_id']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//field[@name='inbound_payment_method_line_ids']//list//field[@name='name']" position="after">
                <field name="x_care_payment_code"/>
            </xpath>
        </field>
    </record>
</odoo>
