<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_care_connector" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.care.connector</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Care Connector" name="care_connector">
                    <block title="Invoice Settings" name="care_invoice_settings_block">
                        <setting id="invoice_cash_rounding_setting" string="Invoice Rounding"
                                 help="Default cash rounding method to apply on invoices created via Care connector">
                            <field name="invoice_cash_rounding_id"/>
                        </setting>
                    </block>
                    <block title="Payment Method Restriction" name="care_credit_payment_settings_block">
                        <setting id="care_credit_journal_setting"
                                 string="Restricted Payment Journal"
                                 help="Select a journal that requires per-partner payment method validation. Only payment method lines from this journal will be available as allowed methods on partners.">
                            <field name="care_credit_journal_id"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>

