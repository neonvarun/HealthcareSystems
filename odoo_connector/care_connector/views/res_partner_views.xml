<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_view" model="ir.ui.view">
            <field name="name">res.partner.form.view</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='function']" position="after">
                    <field name="ref" readonly="1"/>
                    <field name="x_care_id" readonly="1"/>
                    <field name="x_care_id_type" readonly="1"/>
                    <field name="x_gender"/>
                    <field name="x_birthdate"/>
                    <field name="x_age" readonly="1"/>
                </xpath>
                <xpath expr="//page[@name='sales_purchases']" position="after">
                    <page string="Allowed Payment Methods" name="allowed_payment_methods">
                        <field name="x_allowed_payment_method_line_ids">
                            <list editable="bottom">
                                <field name="restricted_journal_id" column_invisible="1"/>
                                <field name="payment_method_line_id"
                                       domain="[('journal_id', '=', restricted_journal_id), ('payment_type', '=', 'inbound')]"
                                       options="{'no_create': True}"/>
                                <field name="date_from"/>
                                <field name="date_to"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>