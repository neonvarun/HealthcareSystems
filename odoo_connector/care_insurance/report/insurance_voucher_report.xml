<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Paper Format for Insurance Voucher (must be defined first) -->
    <record id="insurance_voucher_paperformat" model="report.paperformat">
        <field name="name">Insurance Voucher Format</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- Insurance Voucher Report Action -->
    <record id="action_report_insurance_voucher" model="ir.actions.report">
        <field name="name">Insurance Claim Voucher</field>
        <field name="model">insurance.claim</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">care_insurance.report_insurance_voucher</field>
        <field name="report_file">care_insurance.report_insurance_voucher</field>
        <field name="print_report_name">'Insurance_Voucher_%s' % object.name</field>
        <field name="binding_model_id" ref="model_insurance_claim"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="insurance_voucher_paperformat"/>
    </record>
</odoo>
