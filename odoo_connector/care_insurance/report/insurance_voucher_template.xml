<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_insurance_voucher">
        <t t-call="web.html_container">
            <!-- CSS to prevent page break issues and set base font size -->
            <style>
                tr, td, th {
                    page-break-inside: avoid !important;
                }
                table {
                    page-break-inside: auto;
                }
                tbody tr {
                    page-break-inside: avoid !important;
                    page-break-after: auto;
                }
            </style>
            <t t-foreach="docs" t-as="claim">
                <!-- Filter categories for report (sorted by sequence for UI ordering) -->
                <t t-set="included_categories" t-value="claim.category_ids.filtered(lambda c: c.include_in_report).sorted('sequence')"/>
                <t t-set="categories_with_lines" t-value="claim.category_ids.filtered(lambda c: c.include_in_report and c.print_line_items and not c.is_manual).sorted('sequence')"/>
                
                <t t-call="web.external_layout">
                    <!-- PAGE 1: Category Summary -->
                    <div class="page" style="font-family: system-ui, -apple-system, sans-serif; font-size: 1rem;">
                        <!-- Space for pre-printed letterhead -->
                        <div style="height: 80px;"></div>

                        <!-- FINAL BILL Title -->
                        <div class="mb-5" style="text-align: left;">
                            <h2 style="font-size: 1.5rem; font-weight: 700; color: #111827; margin: 0;">
                                FINAL BILL
                            </h2>
                        </div>

                        <!-- Patient Info and Bill Details - Two Column Layout -->
                        <div class="d-flex justify-content-between mb-3" style="font-size: 1rem;">
                            <!-- Left Column: Name and Address -->
                            <div style="width: 55%;">
                                <table style="border-collapse: collapse;">
                                    <tr>
                                        <td style="font-weight: 600; padding: 2px 8px 2px 0; vertical-align: top;">Name</td>
                                        <td style="padding: 2px 8px 2px 0; vertical-align: top;">:</td>
                                        <td style="font-weight: 600; padding: 2px 0;">
                                            <t t-if="claim.customer_id.name"><span t-field="claim.customer_id.name"/></t>
                                            <t t-else="">-</t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight: 600; padding: 2px 8px 2px 0; vertical-align: top;">Address</td>
                                        <td style="padding: 2px 8px 2px 0; vertical-align: top;">:</td>
                                        <td style="padding: 2px 0; line-height: 1.4;">
                                            <t t-if="claim.customer_id.street or claim.customer_id.street2 or claim.customer_id.city">
                                                <t t-if="claim.customer_id.street"><span t-field="claim.customer_id.street"/><br/></t>
                                                <t t-if="claim.customer_id.street2"><span t-field="claim.customer_id.street2"/><br/></t>
                                                <t t-if="claim.customer_id.city"><span t-field="claim.customer_id.city"/></t>
                                                <t t-if="claim.customer_id.state_id">
                                                    <t t-if="claim.customer_id.city">, </t>
                                                    <span t-field="claim.customer_id.state_id.name"/>
                                                </t>
                                                <t t-if="claim.customer_id.zip"> <span t-field="claim.customer_id.zip"/></t>
                                                <t t-if="claim.customer_id.phone"><br/><span t-field="claim.customer_id.phone"/></t>
                                            </t>
                                            <t t-else="">-</t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 2px 8px 2px 0; vertical-align: top;">Age</td>
                                        <td style="padding: 2px 8px 2px 0; vertical-align: top;">:</td>
                                        <td style="padding: 2px 0;"><t t-if="claim.age"><span t-field="claim.age"/> years</t><t t-else="">-</t></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 2px 8px 2px 0; vertical-align: top;">Gender</td>
                                        <td style="padding: 2px 8px 2px 0; vertical-align: top;">:</td>
                                        <td style="padding: 2px 0;"><t t-if="claim.gender"><span t-field="claim.gender"/></t><t t-else="">-</t></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 2px 8px 2px 0; vertical-align: top;">Doctor</td>
                                        <td style="padding: 2px 8px 2px 0; vertical-align: top;">:</td>
                                        <td style="padding: 2px 0;"><t t-if="claim.doctor"><span t-field="claim.doctor"/></t><t t-else="">-</t></td>
                                    </tr>
                                </table>
                            </div>

                            <!-- Right Column: Bill Details -->
                            <div style="width: 42%;">
                                <table style="border-collapse: collapse; width: 100%;">
                                    <tr>
                                        <td style="padding: 2px 8px 2px 0;">IP Bill No</td>
                                        <td style="padding: 2px 8px 2px 0;">:</td>
                                        <td style="padding: 2px 0;"><t t-if="claim.ip_bill_no"><span t-field="claim.ip_bill_no"/></t><t t-else="">-</t></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 2px 8px 2px 0;">Date</td>
                                        <td style="padding: 2px 8px 2px 0;">:</td>
                                        <td style="padding: 2px 0;"><t t-if="claim.bill_generated_on"><span t-field="claim.bill_generated_on" t-options='{"widget": "date", "format": "dd-MM-yyyy"}'/></t><t t-else="">-</t></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 2px 8px 2px 0;">SSMM ID</td>
                                        <td style="padding: 2px 8px 2px 0;">:</td>
                                        <td style="padding: 2px 0;"><t t-if="claim.customer_care_id"><span t-field="claim.customer_care_id"/></t><t t-else="">-</t></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 2px 8px 2px 0;">Room No</td>
                                        <td style="padding: 2px 8px 2px 0;">:</td>
                                        <td style="padding: 2px 0;"><t t-if="claim.room_number"><span t-field="claim.room_number"/></t><t t-else="">-</t></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 2px 8px 2px 0;">No. of Days</td>
                                        <td style="padding: 2px 8px 2px 0;">:</td>
                                        <td style="padding: 2px 0;"><t t-if="claim.no_of_days"><span t-field="claim.no_of_days"/></t><t t-else="">-</t></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 2px 8px 2px 0;">Admission Date</td>
                                        <td style="padding: 2px 8px 2px 0;">:</td>
                                        <td style="padding: 2px 0;"><t t-if="claim.admission_date"><span t-field="claim.admission_date" t-options='{"widget": "datetime", "format": "dd-MM-yyyy hh:mm a"}'/></t><t t-else="">-</t></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 2px 8px 2px 0;">Discharge Date</td>
                                        <td style="padding: 2px 8px 2px 0;">:</td>
                                        <td style="padding: 2px 0;"><t t-if="claim.discharge_date"><span t-field="claim.discharge_date" t-options='{"widget": "datetime", "format": "dd-MM-yyyy hh:mm a"}'/></t><t t-else="">-</t></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Category Summary Table -->
                        <div style="border: 1px solid #d1d5db; border-radius: 4px 4px 0 0;">
                            <table class="table table-sm mb-0" style="font-size: 1rem;">
                                <thead>
                                    <tr style="border-bottom: 1px solid #e5e7eb;">
                                        <th class="text-center" style="border-right: 1px solid #e5e7eb; font-weight: 500; width: 5%;">#</th>
                                        <th style="border-right: 1px solid #e5e7eb; font-weight: 500;">Category</th>
                                        <th class="text-center" style="border-right: 1px solid #e5e7eb; font-weight: 500; width: 10%;">Qty</th>
                                        <th class="text-end" style="border-right: 1px solid #e5e7eb; font-weight: 500; width: 15%;">Rate (₹)</th>
                                        <th class="text-end" style="font-weight: 500; width: 15%;">Amount (₹)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="sl_no" t-value="1"/>
                                    <t t-foreach="included_categories" t-as="category">
                                        <tr style="border-bottom: 1px solid #e5e7eb;">
                                            <td class="text-center" style="border-right: 1px solid #e5e7eb; color: #111827;">
                                                <t t-esc="sl_no"/>
                                            </td>
                                            <td style="border-right: 1px solid #e5e7eb; font-weight: 500; color: #111827;">
                                                <t t-esc="category.category_name"/>
                                            </td>
                                            <td class="text-center" style="border-right: 1px solid #e5e7eb; color: #111827;">
                                                <span t-esc="'%.0f' % category.insurance_quantity"/>
                                            </td>
                                            <td class="text-end" style="border-right: 1px solid #e5e7eb; color: #111827;">
                                                <span t-esc="'%.2f' % category.insurance_rate"/>
                                            </td>
                                            <td class="text-end" style="color: #111827; font-weight: 600;">
                                                <span t-esc="'%.2f' % category.insurance_amount"/>
                                            </td>
                                        </tr>
                                        <t t-set="sl_no" t-value="sl_no + 1"/>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Totals -->
                        <div style="border: 1px solid #d1d5db; border-top: none; border-radius: 0 0 4px 4px; padding: 0.75rem;">
                            <div class="d-flex flex-column align-items-end" style="font-size: 1rem; color: #111827;">
                                <t t-set="insurance_total" t-value="sum(included_categories.mapped('insurance_amount'))"/>
                                <div class="d-flex justify-content-between" style="width: 18rem; font-weight: 600; font-size: 1.125rem;">
                                    <span>Total Amount</span>
                                    <span>₹<t t-esc="'%.2f' % insurance_total"/></span>
                                </div>
                                <div style="padding: 0.25rem; border-top: 2px dashed #e5e7eb; width: 100%; margin: 0.5rem 0;"/>
                                <t t-if="claim.approved_amount">
                                    <div class="d-flex justify-content-between" style="width: 18rem;">
                                        <span style="color: #6b7280;">Approved Amount:</span>
                                        <span style="font-weight: 600;">
                                            <span t-field="claim.approved_amount" t-options='{"widget": "monetary", "display_currency": claim.currency_id}'/>
                                        </span>
                                    </div>
                                    <t t-if="claim.approved_date">
                                        <div class="d-flex justify-content-between" style="width: 18rem; font-size: 0.9rem;">
                                            <span style="color: #6b7280;">Approved Date:</span>
                                            <span t-field="claim.approved_date" t-options='{"widget": "date"}'/>
                                        </div>
                                    </t>
                                </t>
                            </div>
                        </div>

                        <!-- Notes -->
                        <t t-if="claim.narration">
                            <div class="mt-4 pt-3" style="border-top: 1px solid #e5e7eb;">
                                <h4 style="font-size: 1rem; font-weight: 500; color: #111827;">Notes</h4>
                                <p style="font-size: 1rem; margin-top: 0.25rem;" t-field="claim.narration"/>
                            </div>
                        </t>

                        <!-- Signature -->
                        <div class="d-flex justify-content-between mt-5">
                            <div>
                                <p style="font-size: 1rem; color: #374151;">Prepared By: <span t-esc="user.name"/></p>
                            </div>
                            <div class="text-end">
                                <p style="font-size: 1rem; font-weight: 600; color: #111827;">
                                    For <span t-field="claim.company_id.name"/>
                                </p>
                                <br/><br/>
                                <p style="font-size: 1rem; color: #374151;">Authorized Signatory</p>
                            </div>
                        </div>
                    </div>

                    <!-- LINE ITEM DETAIL PAGES: One page per category -->
                    <t t-foreach="categories_with_lines" t-as="cat">
                        <!-- Filter lines by root category using parent_path (includes all child categories) -->
                        <t t-set="root_path_prefix" t-value="str(cat.category_id.id) + '/' if cat.category_id else ''"/>
                        <t t-if="cat.category_id">
                            <t t-set="category_lines" t-value="claim.claimed_move_line_ids.filtered(lambda l: l.product_id.categ_id.parent_path and l.product_id.categ_id.parent_path.startswith(root_path_prefix))"/>
                        </t>
                        <t t-else="">
                            <t t-set="category_lines" t-value="claim.claimed_move_line_ids.filtered(lambda l: not l.product_id.categ_id)"/>
                        </t>
                        <t t-if="category_lines">
                            <div class="page" style="font-family: system-ui, -apple-system, sans-serif; font-size: 1rem; page-break-before: always;">

                                <!-- LINE ITEMS Title -->
                                <div class="mb-5" style="text-align: center;">
                                    <h2 style="font-size: 1.5rem; font-weight: 700; color: #111827; margin: 0;">
                                        DISCHARGE BILL - <span t-esc="cat.category_name.upper()"/>
                                    </h2>
                                </div>

                                <!-- Patient Info and Bill Details - Two Column Layout -->
                                <div class="d-flex justify-content-between mb-3" style="font-size: 1rem;">
                                    <!-- Left Column: Name and Address -->
                                    <div style="width: 55%;">
                                        <table style="border-collapse: collapse;">
                                            <tr>
                                                <td style="font-weight: 600; padding: 2px 8px 2px 0; vertical-align: top;">Name</td>
                                                <td style="padding: 2px 8px 2px 0; vertical-align: top;">:</td>
                                                <td style="font-weight: 600; padding: 2px 0;">
                                                    <t t-if="claim.customer_id.name"><span t-field="claim.customer_id.name"/></t>
                                                    <t t-else="">-</t>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="font-weight: 600; padding: 2px 8px 2px 0; vertical-align: top;">Address</td>
                                                <td style="padding: 2px 8px 2px 0; vertical-align: top;">:</td>
                                                <td style="padding: 2px 0; line-height: 1.4;">
                                                    <t t-if="claim.customer_id.street or claim.customer_id.street2 or claim.customer_id.city">
                                                        <t t-if="claim.customer_id.street"><span t-field="claim.customer_id.street"/><br/></t>
                                                        <t t-if="claim.customer_id.street2"><span t-field="claim.customer_id.street2"/><br/></t>
                                                        <t t-if="claim.customer_id.city"><span t-field="claim.customer_id.city"/></t>
                                                        <t t-if="claim.customer_id.state_id">
                                                            <t t-if="claim.customer_id.city">, </t>
                                                            <span t-field="claim.customer_id.state_id.name"/>
                                                        </t>
                                                        <t t-if="claim.customer_id.zip"> <span t-field="claim.customer_id.zip"/></t>
                                                        <t t-if="claim.customer_id.phone"><br/><span t-field="claim.customer_id.phone"/></t>
                                                    </t>
                                                    <t t-else="">-</t>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 8px 2px 0; vertical-align: top;">Age</td>
                                                <td style="padding: 2px 8px 2px 0; vertical-align: top;">:</td>
                                                <td style="padding: 2px 0;"><t t-if="claim.age"><span t-field="claim.age"/> years</t><t t-else="">-</t></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 8px 2px 0; vertical-align: top;">Gender</td>
                                                <td style="padding: 2px 8px 2px 0; vertical-align: top;">:</td>
                                                <td style="padding: 2px 0;"><t t-if="claim.gender"><span t-field="claim.gender"/></t><t t-else="">-</t></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 8px 2px 0; vertical-align: top;">Doctor</td>
                                                <td style="padding: 2px 8px 2px 0; vertical-align: top;">:</td>
                                                <td style="padding: 2px 0;"><t t-if="claim.doctor"><span t-field="claim.doctor"/></t><t t-else="">-</t></td>
                                            </tr>
                                        </table>
                                    </div>

                                    <!-- Right Column: Bill Details -->
                                    <div style="width: 42%;">
                                        <table style="border-collapse: collapse; width: 100%;">
                                            <tr>
                                                <td style="padding: 2px 8px 2px 0;">IP Bill No</td>
                                                <td style="padding: 2px 8px 2px 0;">:</td>
                                                <td style="padding: 2px 0;"><t t-if="claim.ip_bill_no"><span t-field="claim.ip_bill_no"/></t><t t-else="">-</t></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 8px 2px 0;">Date</td>
                                                <td style="padding: 2px 8px 2px 0;">:</td>
                                                <td style="padding: 2px 0;"><t t-if="claim.bill_generated_on"><span t-field="claim.bill_generated_on" t-options='{"widget": "date", "format": "dd-MM-yyyy"}'/></t><t t-else="">-</t></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 8px 2px 0;">SSMM ID</td>
                                                <td style="padding: 2px 8px 2px 0;">:</td>
                                                <td style="padding: 2px 0;"><t t-if="claim.customer_care_id"><span t-field="claim.customer_care_id"/></t><t t-else="">-</t></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 8px 2px 0;">Room No</td>
                                                <td style="padding: 2px 8px 2px 0;">:</td>
                                                <td style="padding: 2px 0;"><t t-if="claim.room_number"><span t-field="claim.room_number"/></t><t t-else="">-</t></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 8px 2px 0;">No. of Days</td>
                                                <td style="padding: 2px 8px 2px 0;">:</td>
                                                <td style="padding: 2px 0;"><t t-if="claim.no_of_days"><span t-field="claim.no_of_days"/></t><t t-else="">-</t></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 8px 2px 0;">Admission Date</td>
                                                <td style="padding: 2px 8px 2px 0;">:</td>
                                                <td style="padding: 2px 0;"><t t-if="claim.admission_date"><span t-field="claim.admission_date" t-options='{"widget": "datetime", "format": "dd-MM-yyyy hh:mm a"}'/></t><t t-else="">-</t></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 8px 2px 0;">Discharge Date</td>
                                                <td style="padding: 2px 8px 2px 0;">:</td>
                                                <td style="padding: 2px 0;"><t t-if="claim.discharge_date"><span t-field="claim.discharge_date" t-options='{"widget": "datetime", "format": "dd-MM-yyyy hh:mm a"}'/></t><t t-else="">-</t></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>

                                <!-- Line Items Table -->
                                <div style="border: 1px solid #d1d5db; border-radius: 4px; margin-bottom: 1rem;">
                                    <table class="table table-sm mb-0" style="font-size: 0.9rem;">
                                        <thead>
                                            <tr style="border-bottom: 1px solid #e5e7eb; background-color: #f9fafb;">
                                                <th class="text-center" style="border-right: 1px solid #e5e7eb; font-weight: 500; width: 4%;">#</th>
                                                <th style="border-right: 1px solid #e5e7eb; font-weight: 500; width: 14%;">Invoice No</th>
                                                <th style="border-right: 1px solid #e5e7eb; font-weight: 500; width: 12%;">Invoice Date</th>
                                                <th style="border-right: 1px solid #e5e7eb; font-weight: 500;">Description</th>
                                                <th class="text-center" style="border-right: 1px solid #e5e7eb; font-weight: 500; width: 6%;">Qty</th>
                                                <th class="text-end" style="border-right: 1px solid #e5e7eb; font-weight: 500; width: 10%;">Rate (₹)</th>
                                                <th class="text-end" style="font-weight: 500; width: 10%;">Amount (₹)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-set="line_no" t-value="1"/>
                                            <t t-set="line_total" t-value="0"/>
                                            <t t-foreach="category_lines" t-as="line">
                                                <!-- Sign: negative for credit notes (out_refund), positive for invoices -->
                                                <t t-set="sign" t-value="-1 if line.move_id.move_type == 'out_refund' else 1"/>
                                                <!-- Get tax rate from line's own tax (not category's tax) -->
                                                <t t-set="line_tax_rate" t-value="line.tax_ids[0].amount if line.tax_ids else 0.0"/>
                                                <t t-set="tax_multiplier" t-value="1 + (line_tax_rate / 100)"/>
                                                <!-- Calculate tax-inclusive values using line's actual tax rate -->
                                                <t t-set="tax_inclusive_rate" t-value="line.price_unit * tax_multiplier * sign"/>
                                                <t t-set="tax_inclusive_amount" t-value="line.price_subtotal * tax_multiplier * sign"/>
                                                <tr style="border-bottom: 1px solid #e5e7eb;">
                                                    <td class="text-center" style="border-right: 1px solid #e5e7eb; color: #111827;">
                                                        <t t-esc="line_no"/>
                                                    </td>
                                                    <td style="border-right: 1px solid #e5e7eb; color: #111827;">
                                                        <span t-field="line.move_id.name"/>
                                                    </td>
                                                    <td style="border-right: 1px solid #e5e7eb; color: #111827;">
                                                        <span t-field="line.move_id.invoice_date" t-options='{"widget": "date", "format": "dd MMM yyyy"}'/>
                                                    </td>
                                                    <td style="border-right: 1px solid #e5e7eb; color: #111827;">
                                                        <t t-esc="line.name or line.product_id.name"/>
                                                    </td>
                                                    <td class="text-center" style="border-right: 1px solid #e5e7eb; color: #111827;">
                                                        <span t-esc="'%.2f' % (line.quantity * sign)"/>
                                                    </td>
                                                    <td class="text-end" style="border-right: 1px solid #e5e7eb; color: #111827;">
                                                        <!-- Tax-inclusive rate using line's actual tax -->
                                                        <span t-esc="'%.2f' % tax_inclusive_rate"/>
                                                    </td>
                                                    <td class="text-end" style="color: #111827;">
                                                        <!-- Tax-inclusive amount using line's actual tax -->
                                                        <span t-esc="'%.2f' % tax_inclusive_amount"/>
                                                    </td>
                                                </tr>
                                                <t t-set="line_no" t-value="line_no + 1"/>
                                                <t t-set="line_total" t-value="line_total + tax_inclusive_amount"/>
                                            </t>
                                        </tbody>
                                        <tfoot>
                                            <tr style="background-color: #f3f4f6;">
                                                <td colspan="6" class="text-end" style="font-weight: 600;">
                                                    Category Total (Incl. Tax):
                                                </td>
                                                <td class="text-end" style="font-weight: 600;">
                                                    ₹<t t-esc="'%.2f' % line_total"/>
                                                </td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </t>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
