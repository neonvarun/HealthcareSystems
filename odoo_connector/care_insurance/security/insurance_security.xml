<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Insurance User Group -->
    <record id="group_insurance_user" model="res.groups">
        <field name="name">Insurance / User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Can create and manage own insurance claims</field>
    </record>

    <!-- Insurance Manager Group -->
    <record id="group_insurance_manager" model="res.groups">
        <field name="name">Insurance / Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_insurance_user'))]"/>
        <field name="comment">Can approve, reject, and manage all insurance claims</field>
    </record>

    <!-- Record Rules -->
    
    <!-- Insurance Claims: Users see only their own company's claims -->
    <record id="insurance_claim_company_rule" model="ir.rule">
        <field name="name">Insurance Claim: Multi-Company</field>
        <field name="model_id" ref="model_insurance_claim"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Insurance Company: Users see only their own company's records -->
    <record id="insurance_company_company_rule" model="ir.rule">
        <field name="name">Insurance Company: Multi-Company</field>
        <field name="model_id" ref="model_insurance_company"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
