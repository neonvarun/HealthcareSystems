<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Extend Account Move Form to show insurance tag -->
    <record id="view_move_form_inherit_insurance" model="ir.ui.view">
        <field name="name">account.move.form.inherit.insurance</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="is_insurance"
                       invisible="move_type not in ('out_invoice', 'out_refund')"/>
                <field name="insurance_tag" invisible="1"/>
                <field name="doctor"
                       invisible="move_type not in ('out_invoice', 'out_refund')"/>
                <field name="admission_date"
                       invisible="move_type not in ('out_invoice', 'out_refund')"/>
                <field name="discharge_date"
                       invisible="move_type not in ('out_invoice', 'out_refund')"/>
                <field name="x_account"
                       invisible="move_type not in ('out_invoice', 'out_refund')"/>
                <field name="ip_bill_no"
                       invisible="move_type not in ('out_invoice', 'out_refund')"/>
            </xpath>
        </field>
    </record>
</odoo>
