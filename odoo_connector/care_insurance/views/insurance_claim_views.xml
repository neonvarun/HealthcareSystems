<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Insurance Claim List View -->
    <record id="insurance_claim_view_list" model="ir.ui.view">
        <field name="name">insurance.claim.list</field>
        <field name="model">insurance.claim</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'"
                  decoration-warning="state == 'confirmed'"
                  decoration-success="state in ('approved', 'reconciled')"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="insurance_company_id"/>
                <field name="total_insurance_amount" string="Total Amount"/>
                <field name="approved_amount"/>
                <field name="approved_date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state in ('approved', 'reconciled')"
                       decoration-danger="state == 'rejected'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Insurance Claim Form View -->
    <record id="insurance_claim_view_form" model="ir.ui.view">
        <field name="name">insurance.claim.form</field>
        <field name="model">insurance.claim</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_fetch_invoice_lines"
                            type="object"
                            string="Fetch Invoice Lines"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_confirm"
                            type="object"
                            string="Confirm"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_approve"
                            type="object"
                            string="Approve"
                            class="oe_highlight"
                            invisible="state != 'confirmed'"
                            groups="care_insurance.group_insurance_manager"
                            confirm="Are you sure you want to approve this claim? This will create a journal entry."/>
                    <button name="action_reject"
                            type="object"
                            string="Reject"
                            class="btn-secondary"
                            invisible="state != 'confirmed'"
                            groups="care_insurance.group_insurance_manager"/>
                    <button name="action_reconcile"
                            type="object"
                            string="Reconcile"
                            class="oe_highlight"
                            invisible="state != 'approved'"
                            confirm="Are you sure you want to reconcile this claim? This will match the insurance journal entry with the customer invoices."/>
                    <button name="action_undo_approval"
                            type="object"
                            string="Undo Approval"
                            class="btn-secondary"
                            invisible="state != 'approved'"
                            groups="care_insurance.group_insurance_manager"
                            confirm="Are you sure you want to undo the approval? The posted journal entry will be deleted and the claim will return to Confirmed."/>
                    <button name="action_undo_reconcile"
                            type="object"
                            string="Undo Reconcile"
                            class="btn-secondary"
                            invisible="state != 'reconciled'"
                            confirm="Are you sure you want to undo the reconciliation? This will unlink the matched journal items and revert the claim to Approved state."/>
                    <button name="action_reset_to_draft"
                            type="object"
                            string="Reset to Draft"
                            class="btn-secondary"
                            invisible="state not in ('confirmed', 'rejected')"/>
                    <button name="action_print_voucher"
                            type="object"
                            string="Print Voucher"
                            class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,approved,reconciled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_journal_entry"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-book"
                                invisible="not journal_entry_id">
                            <span class="o_stat_text">Journal Entry</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="customer_id" readonly="state != 'draft'"/>
                            <field name="insurance_company_id" readonly="state != 'draft'"/>
                            <field name="journal_id" readonly="state != 'draft'"/>
                            <field name="journal_ref" readonly="state != 'draft'"/>
                            <field name="approved_amount" readonly="state not in ('draft', 'confirmed')"/>
                            <field name="approved_date" readonly="state not in ('draft', 'confirmed')"/>
                        </group>
                        <group string="Patient Info">
                            <field name="age"/>
                            <field name="gender"/>
                            <label for="customer_street" string="Address"/>
                            <div>
                                <field name="customer_street" nolabel="1" placeholder="Street"/>
                                <field name="customer_street2" nolabel="1" placeholder="Street 2"/>
                                <field name="customer_city" nolabel="1" class="o_address_city" placeholder="City"/>
                                <field name="customer_zip" nolabel="1" class="o_address_zip" placeholder="ZIP"/>
                                <field name="customer_state_id" nolabel="1" placeholder="State" options="{'no_create': True}"/>
                                <field name="customer_country_id" nolabel="1" placeholder="Country" options="{'no_create': True}"/>
                            </div>
                        </group>
                        <group string="Hospital Info">
                            <field name="doctor" readonly="state != 'draft'"/>
                            <field name="room_number" readonly="state != 'draft'"/>
                            <field name="claim_number" readonly="state != 'draft'"/>
                            <field name="no_of_days" readonly="state != 'draft'"/>
                            <field name="admission_date" readonly="state != 'draft'"/>
                            <field name="discharge_date" readonly="state != 'draft'"/>
                        </group>
                        <group string="Invoice Info">
                            <field name="customer_care_id"/>
                            <field name="account"/>
                            <field name="ip_bill_no"/>
                            <field name="bill_generated_on"/>
                        </group>
                    </group>

                    <!-- Rejection reason (only shown when rejected) -->
                    <group invisible="state != 'rejected'">
                        <field name="rejection_reason" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Category Summary" name="category_summary">
                            <field name="category_ids" nolabel="1" readonly="state != 'draft'">
                                <list editable="bottom" create="true" delete="true">
                                    <field name="sequence" widget="handle"/>
                                    <field name="is_manual" column_invisible="1"/>
                                    <field name="category_id" column_invisible="1"/>
                                    <field name="category_name" string="Category"/>
                                    <!-- Original values (readonly) -->
                                    <field name="original_quantity" string="Orig. Qty" readonly="1"/>
                                    <field name="original_rate" string="Orig. Rate" readonly="1"/>
                                    <field name="original_amount" string="Orig. Amount" readonly="1" sum="Total Original"/>
                                    <!-- Insurance values (qty/rate editable, amount computed) -->
                                    <field name="insurance_quantity" string="Ins. Qty"/>
                                    <field name="insurance_rate" string="Ins. Rate"/>
                                    <field name="insurance_amount" string="Ins. Amount" readonly="1" sum="Total Insurance"/>
                                    <!-- Checkboxes -->
                                    <field name="include_in_report" string="Include" width="80px"/>
                                    <field name="print_line_items" string="Print Items" width="80px"
                                           readonly="is_manual"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_original_amount" string="Total Original"/>
                                <field name="total_insurance_amount" string="Total Insurance"/>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="narration" placeholder="Internal notes..." readonly="state != 'draft'"/>
                        </page>
                    </notebook>

                    <!-- Hidden fields -->
                    <field name="journal_entry_id" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Insurance Claim Search View -->
    <record id="insurance_claim_view_search" model="ir.ui.view">
        <field name="name">insurance.claim.search</field>
        <field name="model">insurance.claim</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="insurance_company_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Reconciled" name="reconciled" domain="[('state', '=', 'reconciled')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="Customer" name="group_customer" context="{'group_by': 'customer_id'}"/>
                <filter string="Insurance Company" name="group_insurance" context="{'group_by': 'insurance_company_id'}"/>
                <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Approved Date" name="group_date" context="{'group_by': 'approved_date:month'}"/>
            </search>
        </field>
    </record>

    <!-- Insurance Claim Action -->
    <record id="insurance_claim_action" model="ir.actions.act_window">
        <field name="name">Insurance Claims</field>
        <field name="res_model">insurance.claim</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first insurance claim
            </p>
            <p>
                Manage hospital insurance claims: fetch invoice lines, confirm, approve, and reconcile.
            </p>
        </field>
    </record>

    <!-- Root Menu -->
    <menuitem id="menu_insurance_root"
              name="Insurance"
              action="insurance_claim_action"
              sequence="45"/>

    <menuitem id="menu_insurance_claims_parent"
              name="Claims"
              parent="menu_insurance_root"
              sequence="10"/>

    <menuitem id="menu_insurance_claims"
              name="Insurance Claims"
              parent="menu_insurance_claims_parent"
              action="insurance_claim_action"
              sequence="10"/>
</odoo>
