<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Insurance Reject Wizard Form View -->
    <record id="insurance_reject_wizard_view_form" model="ir.ui.view">
        <field name="name">insurance.reject.wizard.form</field>
        <field name="model">insurance.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Insurance Claim">
                <group>
                    <field name="claim_id" invisible="1"/>
                    <field name="reason" placeholder="Enter the reason for rejecting this claim..."/>
                </group>
                <footer>
                    <button name="action_reject"
                            type="object"
                            string="Reject Claim"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

