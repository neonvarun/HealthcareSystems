<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="website_menu_cash_denomination" model="website.menu">
        <field name="name">Cash Denomination</field>
        <field name="url">/cash/denomination</field>
        <field name="sequence">20</field>
        <field name="parent_id" ref="website.main_menu"/>
    </record>
    <template id="website_cash_denomination" name="Cash Denomination">
        <t t-call="website.layout">
            <t t-if="counters">
                <div id="wrap" class="cash_denomination_template" style="min-height:100vh; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                    <section class="container-fluid d-flex justify-content-center align-items-center" style="height:100vh;">
                        <form id="cash_denomination_form" action="/cash/denomination/submit" method="post" class="p-4 border rounded shadow bg-white" style="max-width:90%; max-height:90%; overflow:auto;">

                            <h1 class="text-center mb-4">Cash Denomination</h1>
                            <input type="hidden" id="remark" name="remark"/>

                            <div class="row mb-6">
                                <div class="col-md-2">
                                    <label for="date" class="form-label">Date</label>
                                    <input type="date" name="date" id="date_field" class="form-control" required="required" readonly="readonly"/>
                                </div>

                                <div class="col-md-2">
                                    <label for="person" class="form-label">Person</label>
                                    <input type="text" id="person" name="person" class="form-control" t-att-value="request.env.user.name" readonly="readonly"/>
                                    <input type="hidden" id="logged_user_id" t-att-value="request.env.user.id"/>
                                </div>

                                <div class="col-md-2">
                                    <label for="counter" class="form-label">Counter</label>
                                    <select name="counter" id="counter" class="form-control" required="required">
                                        <option value="" disabled="disabled" selected="selected">Select Counter</option>
                                        <t t-foreach="counters" t-as="ctr">
                                            <option t-att-value="ctr.id">
                                                <t t-esc="ctr.bill_counter"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label">Cash In Hand</label>
                                    <input type="text" name="total_cash_field" class="form-control" t-att-value="total_cash or '0.00'" id="total_cash_field" readonly="readonly"/>
                                </div>
                                <div class="col-md-2">
                                    <strong>
                                        <p id="transfer_cash_amount_text" style="font-size:20px; margin-top:5px; margin-top:35px">Transfer Cash:<span id="counter_transfer_amount"/>
                                        </p>
                                    </strong>
                                </div>
                            </div>

                            <div style="max-height:50vh; overflow-y:auto; margin-top:15px">
                                <table class="table table-bordered text-center">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Count</th>
                                            <th>Currency</th>
                                            <th>Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="denominations" t-as="val">
                                            <td>
                                                <input type="number" min="0" t-att-name="'counts_%s' % val" class="form-control counts-input" t-att-data-value="val"/>
                                            </td>
                                            <td>
                                                <input type="text" class="form-control" t-att-value="val" readonly="readonly"/>
                                            </td>
                                            <td>
                                                <input type="text" class="form-control total-field" readonly="readonly"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Submit -->
                            <div class="d-flex justify-content-center align-items-center mt-4 position-relative">
                                <div class="mx-auto">
                                    <button type="button" class="btn" id="cash_transfer_btn" style="background-color: #bcb9bc;">Transfer Cash</button>
                                    <button type="submit" class="btn btn-primary px-4">Confirm Cash Count</button>
                                    <button type="button" class="btn" id="submit_account_btn" style="background-color: #994893;">Submit to Accounts</button>
                                </div>

                                <div class="position-absolute" style="right: 0;">
                                    <strong>Total Amount: </strong>
                                    <input type="text" id="grand_total" name="grand_total" class="form-control d-inline-block" style="width:150px;" readonly="readonly"/>
                                </div>
                            </div>
                        </form>
                        <!-- Cash Transfer Modal -->
                        <div class="modal fade" id="cash_transfer_modal" tabindex="-1" aria-labelledby="CashTransferModalLabel" aria-hidden="true">
                            <div class="modal-dialog modal-lg modal-dialog-centered">
                                <div class="modal-content">

                                    <div class="modal-header bg-primary text-white justify-content-center">
                                        <h4 class="modal-title text-center w-100" id="CashTransferModalLabel">Transfer Cash Denomination</h4>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>

                                    <div class="modal-body">
                                        <form id="cash_tranfer_form" action="/cash/transfer/submit" method="post">
                                            <input type="hidden" name="from_selected_counter" id="from_selected_counter"/>
                                            <input type="hidden" name="logged_user" id="logged_user"/>
                                            <input type="hidden" name="created_date" id="created_date"/>

                                            <div class="mb-3 d-flex align-items-center" style="margin-left:15px;">
                                                <div>
                                                    <label for="to_all_locations" class="form-label me-2 mb-0" style="min-width:90px;">To Location</label>
                                                    <select id="to_all_locations" name="to_all_locations" class="form-select" style="width:250px;" required="required">
                                                        <option value="" disabled="disabled" selected="selected">Select Counter</option>
                                                    </select>
                                                </div>
                                                <div>
                                                    <label for="cashier_id" class="form-label me-2 mb-0" style="min-width:90px;">
                                                        Cashier
                                                    </label>
                                                    <select id="cashier_id" name="cashier_id" class="form-select" style="width:250px;" required="required">
                                                        <option value="" disabled="disabled" selected="selected">Select Cashier</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <table class="table table-bordered text-center">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Count</th>
                                                        <th>Currency</th>
                                                        <th>Total</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr t-foreach="denominations" t-as="val">
                                                        <td>
                                                            <input type="number" min="0" t-att-name="'%s' % val" class="form-control transfer-counts-input" t-att-data-value="val"/>
                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control" t-att-value="val" readonly="readonly"/>
                                                        </td>
                                                        <td>
                                                            <input type="text" class="form-control transfer-total-field" readonly="readonly"/>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>

                                            <div class="d-flex justify-content-center align-items-center mt-4 position-relative" style="margin-bottom:30px;">
                                                <div class="mx-auto">
                                                    <button type="submit" class="btn btn-primary me-2">Submit</button>
                                                    <button type="button" class="btn" style="background-color: #bcb9bc;" data-bs-dismiss="modal">Cancel</button>
                                                </div>

                                                <div class="position-absolute" style="right: 0;">
                                                    <strong>Grand Total: </strong>
                                                    <input type="text" id="transfer_grand_total" class="form-control d-inline-block text-end" style="width:150px;margin-right:10px" readonly="readonly"/>
                                                </div>
                                            </div>
                                        </form>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </section>
                </div>
                <!-- view transfer details  -->
                <div class="modal fade" id="transfer-details-modal" tabindex="-1" aria-labelledby="transfer-details-modal-label" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered modal-md">
                        <div class="modal-content">
                            <div class="modal-header bg-primary text-white justify-content-center">
                                <h4 class="modal-title text-center w-100" id="transfer-details-modal-label">Denomination Details</h4>
                                <button type="button" class="btn-close btn-close-black" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <form id="submit_to_account_form" action="/cash/denomination/submit/to/accounts" method="post">
                                    <div class="mb-3 row align-items-center">
                                        <label class="col-4 col-form-label fw-bold">Counter</label>
                                        <div class="col-8">
                                            <select class="form-control" name="counter_id" id="denomination_counter" required="required">
                                                <t t-foreach="counters" t-as="counter">
                                                    <option t-att-value="counter.id">
                                                        <t t-esc="counter.bill_counter"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>


                                    <div class="mb-3 row align-items-center">
                                        <label class="col-4 col-form-label fw-bold">Cashier</label>
                                        <div class="col-8">
                                            <select class="form-control" name="cashier_name" id="cashier_name" required="required">
                                                <option t-att-value="cashier_name">
                                                    <t t-esc="cashier_name"/>
                                                </option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mb-3 row align-items-center">
                                        <label class="col-4 col-form-label fw-bold">Date</label>
                                        <div class="col-8">
                                            <select class="form-control" name="denomination_date" id="denomination_date" required="required">
                                                <option t-att-value="denomination_date">
                                                    <t t-esc="denomination_date"/>
                                                </option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mb-3 row align-items-center">
                                        <label class="col-4 col-form-label fw-bold">Total Cash Received</label>
                                        <div class="col-8">
                                            <select class="form-control" name="total_amount" id="total_amount" required="required">
                                                <option t-att-value="total_amount">
                                                    <t t-esc="total_amount"/>
                                                </option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mb-3 row align-items-center">
                                        <label class="col-4 col-form-label fw-bold">Total Denomination</label>
                                        <div class="col-8">
                                            <select class="form-control" name="total_denomination" id="total_denomination" required="required">
                                                <option t-att-value="total_denomination">
                                                    <t t-esc="total_denomination"/>
                                                </option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mb-3 row align-items-center">
                                        <label class="col-4 col-form-label fw-bold">Transferred Amount</label>
                                        <div class="col-8">
                                            <select class="form-control" name="total_transfer" id="total_transfer" required="required">
                                                <option t-att-value="total_transfer">
                                                    <t t-esc="total_transfer"/>
                                                </option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mb-3 row align-items-center">
                                        <label class="col-4 col-form-label fw-bold">Pending Amount</label>
                                        <div class="col-8">
                                            <select class="form-control" name="total_pending" id="total_pending" required="required">
                                                <option t-att-value="total_pending">
                                                    <t t-esc="total_pending"/>
                                                </option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-center align-items-center mt-4 position-relative" style="margin-bottom:30px;">
                                        <div class="mx-auto">
                                            <button type="button" id="edit_denomination_btn" class="btn" style="background-color: #f53823ff;color:white">Cancel Denomination</button>
                                            <button type="submit" class="btn btn-primary me-2">Submit</button>
                                        </div>
                                    </div>
                                </form>

                            </div>
                        </div>
                    </div>
                </div>

                <!-- No Cash To Transfer Modal -->
                <div class="modal fade" id="no-cash-modal-transfer" tabindex="-1" aria-labelledby="no-cash-modal-label" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header bg-warning text-dark">
                                <h5 class="modal-title fw-bold text-center w-100" id="no-cash-modal-label">No Cash </h5>
                                <button type="button" class="btn-close btn-close-black" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <p class="fs-5 text-center w-100">You have no cash in hand.</p>
                                <p class="text-muted text-center w-100">Please check your cash in hand and try again later.</p>
                            </div>
                            <div class="modal-footer d-flex justify-content-center">
                                <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Cash Denomination Submission Modal -->
                <div class="modal fade" id="success-modal" tabindex="-1" aria-labelledby="success-modal-label" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content text-center p-3">
                            <div class="modal-header bg-primary text-white">
                                <h5 class="modal-title fw-bold text-center w-100" id="same-counter-modal-label">
                                successfully submitted
                                </h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <p>Your cash denomination has been successfully submitted.</p>
                            </div>
                            <div class="modal-footer d-flex justify-content-center">
                                <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- No Count Entered Modal -->
                <div class="modal fade" id="no-count-modal" tabindex="-1" aria-labelledby="noCountModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header bg-warning text-dark">
                                <h5 class="modal-title text-center w-100" id="noCountModalLabel">No Counts Entered</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body text-center">
                                Please enter at least one denomination count before submitting.
                            </div>
                            <div class="modal-footer d-flex justify-content-center">
                                <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal">OK</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="mismatch-submit-modal" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">

                            <div class="modal-header bg-warning justify-content-center">
                                <h5 class="modal-title">warning: Amount Mismatch</h5>
                            </div>

                            <div class="modal-body">
                                <p>
                                    The counted amount does not match the cash in hand.<br/>
                                    Are you sure you want to submit?
                                </p>

                                <div class="form-group mt-3">
                                    <label for="mismatch_remark">Remark</label>
                                    <textarea id="mismatch_remark" class="form-control" placeholder="Enter reason for mismatch"></textarea>
                                </div>
                            </div>

                            <div class="d-flex justify-content-center align-items-center mt-4 position-relative" style="margin-bottom:10px;">
                                <div class="mx-auto">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                         Cancel
                                    </button>

                                    <button type="button" class="btn btn-primary" id="confirm_mismatch_submit">
                                        Submit Anyway
                                    </button>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <!-- Cash Transfer Success Modal -->
                <div class="modal fade" id="transfer-success-modal" tabindex="-1" aria-labelledby="transfer-success-modal-label" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content text-center p-3">
                            <div class="modal-header bg-primary text-white">
                                <h5 class="modal-title fw-bold text-center w-100" id="transfer-success-modal-label">
                                Transfer Successful
                                </h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <p>Your cash transfer has been successfully submitted.</p>
                            </div>
                            <div class="modal-footer d-flex justify-content-center">
                                <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal">OK</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Submit to account failed modal -->
                <div class="modal fade" id="AccountSubmitFailedModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header bg-info text-white ">
                                <h5 class="modal-title text-center w-100">Failed to submit</h5>
                            </div>

                            <div class="modal-body">
                                <p>
                                    <strong>Please Confirm the Cash count before submit to the accounts</strong>
                                </p>
                            </div>
                            <div class="d-flex justify-content-center align-items-center mt-4 position-relative modal-footer" style="margin-bottom:10px;">
                                <div class="mx-auto">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                         OK
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Denomination Entry Edit modal -->
                <div class="modal fade" id="DenominationEditModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered modal-md">
                        <div class="modal-content shadow-lg rounded-3">

                            <div class="modal-header border-0 bg-light">
                                <div class="text-center w-100">
                                    <i class="fa fa-exclamation-triangle text-warning fs-3 mb-2"></i>
                                    <h5 class="modal-title fw-semibold">Cancel Current Activity
                                    </h5>
                                    <p class="text-muted mb-0 small">Choose what you want to cancel
                                    </p>
                                </div>
                                <button type="button" class="btn-close position-absolute end-0 me-3" data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body px-4 pb-4">
                                <button type="button" id="cancel_denomination_amount" class="btn btn-outline-danger w-100 py-3 mb-3 rounded-3">
                                    <i class="fa fa-ban me-2"></i>ancel Denomination Amount
                                </button>

                                <button type="button" id="cancel_transferred_amount" class="btn btn-outline-warning w-100 py-3 rounded-3">
                                    <i class="fa fa-undo me-2"></i>Cancel Transferred Amount
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Transfer exceeds cash in hand modal -->
                <div class="modal fade" id="transfer-limit-modal" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content text-center">
                            <div class="modal-header bg-danger text-white d-flex justify-content-center position-relative">

                                <h5 class="modal-title w-100 text-center m-0">
                                    Transfer Amount Exceeded!
                                </h5>
                                <button type="button" class="btn-close btn-close-white position-absolute end-0 me-2" data-bs-dismiss="modal"/>
                            </div>

                            <div class="modal-body">
                                <p class="fs-5">
                                    Transfer amount cannot be more than the cash in hand.
                                </p>
                            </div>

                            <div class="modal-footer d-flex justify-content-center">
                                <button class="btn btn-danger px-4" data-bs-dismiss="modal">OK</button>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="modal fade" id="select-counter-modal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered modal-sm">
                        <div class="modal-content">
                            <div class="modal-body text-center p-4">

                                <div class="mb-3">
                                    <i class="fa fa-info-circle" style="font-size: 40px; color: #2196f3;"></i>
                                </div>

                                <h5 class="fw-bold mb-2">Action Cannot Proceed</h5>

                                <p class="text-muted">
                                    A counter must be selected before continuing.  
                                    Please choose one from the dropdown to proceed.
                                </p>

                                <button class="btn btn-primary mt-2" data-bs-dismiss="modal">
                                    Got It
                                </button>

                            </div>
                        </div>
                    </div>
                </div>


            </t>
            <t t-else="">
                <div class="container text-center mt-5">
                    <div class="alert alert-warning shadow p-5" style="max-width:600px; margin:auto;">
                        <h3 class="text-danger mb-3">No Cash Payments Found</h3>
                        <p class="fs-5">There are no cash payment entries available for today. Please enter a payment to proceed with denomination.</p>
                        <a href="/cash/denomination/register" class="btn btn-primary">Go to Denomination Register</a>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>