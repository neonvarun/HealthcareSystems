<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="website_menu_denomination_history" model="website.menu">
        <field name="name">Denomination History</field>
        <field name="sequence">500</field>
        <field name="website_id" ref="website.main_menu"/>
        <field name="parent_id" search="[('parent_id','=',False),('website_id','=',1)]"/>
    </record>

    <record id="website_menu_pending_cash_transfer" model="website.menu">
        <field name="name">Pending Cash Transfer</field>
        <field name="url">/pending/cash/transfer</field>
        <field name="sequence" type="int">10</field>
        <field name="parent_id" ref="cash_denomination.website_menu_denomination_history"/>
        <field name="website_id" ref="website.main_menu"/>
    </record>

    <record id="website_menu_denomination_register" model="website.menu">
        <field name="name">Denomination Register</field>
        <field name="url">/cash/denomination/register</field>
        <field name="sequence">20</field>
        <field name="parent_id" ref="cash_denomination.website_menu_denomination_history"/>
        <field name="website_id" ref="website.main_menu"/>
    </record>

    <record id="website_menu_denomination_payment" model="website.menu">
        <field name="name">Payment Transactions</field>
        <field name="url">/denomination/payment/transactions</field>
        <field name="sequence" type="int">30</field>
        <field name="parent_id" ref="cash_denomination.website_menu_denomination_history"/>
        <field name="website_id" ref="website.main_menu"/>
    </record>

</odoo>