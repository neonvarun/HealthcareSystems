<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="website_cash_denomination_register" name="Cash Denomination List">
        <t t-call="website.layout">
            <div class="cash_denomination_register_template">
                <div class="container mt-4">
                    <h3>
                        <center>Cash Denomination Records</center>
                    </h3>

                    <t t-set="records" t-value="request.env['cash.denomination'].sudo().search([
                       ('user', '=', request.env.user.id)
                        ], order='id desc')"/>
                    <table class="table table-bordered table-striped mt-3" style="table-layout:fixed; width:100%;">
                        <colgroup>
                            <!-- Sl.No column -->
                            <col style="width:70px;"/>
                            <!-- Person -->
                            <col style="width:250px;"/>
                            <!-- Counter -->
                            <col style="width:140px;"/>
                            <!-- Date -->
                            <col style="width:140px;"/>
                            <!-- Remark -->
                            <col style="width:260px;"/>
                            <!-- Status -->
                            <col style="width:100px;"/>
                            <!-- Subtotal -->
                            <col style="width:150px;"/>
                            <!-- Pending -->
                            <col style="width:150px;"/>
                            <!-- Denomination -->
                            <col style="width:150px;"/>
                        </colgroup>
                        <thead class="text-center">
                            <tr>
                                <th>Sl No.</th>
                                <th>Person</th>
                                <th>Counter</th>
                                <th>Date</th>
                                <th>Remark</th>
                                <th>Status</th>
                                <th>Subtotal</th>
                                <th>Pending</th>
                                <th>Denomination</th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-set="sl" t-value="1"/>
                            <t t-foreach="records" t-as="rec">
                                <tr>
                                    <td class="text-center" style="width:20px;">
                                        <t t-esc="sl"/>
                                    </td>

                                    <td>
                                        <t t-esc="rec.user.name"/>
                                    </td>

                                    <td class="text-center">
                                        <t t-esc="rec.counter.bill_counter"/>
                                    </td>

                                    <td class="text-center">
                                        <t t-esc="rec.date"/>
                                    </td>

                                    <td>
                                        <t t-esc="rec.remark or ''"/>
                                    </td>

                                    <td class="text-center">
                                        <t t-esc="rec.state"/>
                                    </td>

                                    <td class="text-center">
                                        <t t-esc="sum(rec.denomination_line_ids.mapped('sub_total'))"/>
                                    </td>

                                    <td>
                                        <t t-esc="rec.pending_amount"/>
                                    </td>

                                    <td class="text-center position-relative">
                                        <button type="button" class="btn btn-primary btn-sm view-denomination-btn" style="width:70px;height:28px;font-size:1rem;border-radius:4px;border:none;" t-att-data-has-lines="1 if rec.denomination_line_ids else 0">
                                            View
                                        </button>

                                        <div class="denomination-box" style="
                                                display:none;
                                                position:absolute;
                                                left:50%;
                                                transform: translateX(-50%);
                                                margin-top:5px;
                                                border:1px solid #ccc;
                                                padding:5px;
                                                background:#f9f9f9;
                                                z-index: 999;
                                                width: 520px;
                                            ">
                                            <span class="close-denomination-btn" style="
                                                position:absolute;
                                                top:3px;
                                                right:1px;
                                                cursor:pointer;
                                                font-size:18px;
                                                font-weight:bold;">
                                            &#215;
                                            </span>
                                            <div class="no-lines-message text-center text-danger" style="display:none; padding:20px;">
                                                No denomination added for this record.
                                            </div>
                                            <table class="table table-bordered table-sm mb-0 denomination-table" style="font-size:12px;width:500px;">
                                                <thead>
                                                    <tr>
                                                        <th>Currency</th>
                                                        <th>Counts</th>
                                                        <th>Sub Total</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="rec.denomination_line_ids" t-as="line">
                                                        <tr>
                                                            <td>
                                                                <t t-esc="line.currency"/>
                                                            </td>
                                                            <td class="text-center">
                                                                <t t-esc="line.counts"/>
                                                            </td>
                                                            <td class="text-right">
                                                                <t t-esc="line.sub_total"/>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                    </td>

                                </tr>
                                <t t-set="sl" t-value="sl + 1"/>
                            </t>

                            <tr t-if="not records">
                                <td colspan="8" class="text-center text-danger">
                                No records found.
                                </td>
                            </tr>

                        </tbody>
                    </table>
                </div>
            </div>
        </t>
    </template>
</odoo>
