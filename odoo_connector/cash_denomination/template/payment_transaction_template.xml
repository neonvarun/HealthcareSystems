<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="cash_transfer_records_template" name="Cash Transfer Records">
        <t t-call="website.layout">

            <div class="container mt-4 cash_transfer_register_template">
                <h3 class="text-center">Cash Transfer Records</h3>
                <t t-set="records" t-value="request.env['cash.transfer'].sudo().search([
                       ('from_user', '=', request.env.user.id)
                        ], order='id desc')"/>
                <table class="table table-bordered table-striped mt-3" style="table-layout:fixed; width:100%">
                    <colgroup>
                        <!-- Sl.No column -->
                        <col style="width:70px;"/>
                        <!-- Person -->
                        <col style="width:250px;"/>
                        <!-- from counter -->
                        <col style="width:140px;"/>
                        <!-- to counter -->
                        <col style="width:140px;"/>
                        <!-- Date -->
                        <col style="width:140px;"/>
                        <!-- Transfer Number -->
                        <col style="width:140px;"/>
                        <!-- Subtotal -->
                        <col style="width:150px;"/>
                        <!-- Status -->
                        <col style="width:120px;"/>
                        <!-- Denomination -->
                        <col style="width:140px;"/>
                        
                    </colgroup>
                    <thead class="text-center">
                        <tr>
                            <th>Sl No</th>
                            <th>Person</th>
                            <th>From Counter</th>
                            <th>To Counter</th>
                            <th>Date</th>
                            <th>Transfer Number</th>
                            <th>Subtotal</th>
                            <th>Status</th>
                            <th>Denomination</th>
                        </tr>
                    </thead>

                    <tbody>
                        <t t-set="sl" t-value="1"/>
                        <t t-foreach="records" t-as="rec">
                            <tr>
                                <td class="text-center">
                                    <t t-esc="sl"/>
                                </td>

                                <td>
                                    <t t-esc="rec.from_user.name"/>
                                </td>

                                <td class="text-center">
                                    <t t-esc="rec.from_location.bill_counter"/>
                                </td>

                                <td class="text-center">
                                    <t t-esc="rec.to_location.bill_counter"/>
                                </td>


                                <td class="text-center">
                                    <t t-esc="rec.date"/>
                                </td>

                                <td>
                                    <t t-esc="rec.name"/>
                                </td>

                                <td class="text-right">
                                    <t t-esc="rec.grand_total"/>
                                </td>

                                <td class="text-center">
                                    <t t-esc="rec.state"/>
                                </td>

                                <td class="text-center position-relative">

                                    <!-- Button -->
                                    <button type="button" class="btn btn-primary btn-sm view-transfer-btn" style="width:70px;height:28px;font-size:1rem;border-radius:4px;border:none;" t-att-data-has-lines="1 if rec.line_ids else 0">
                                        View
                                    </button>

                                    <!-- Slide box -->
                                    <div class="transfer-box" style="display:none; position:absolute; left:50%;
                                         transform:translateX(-50%); margin-top:5px;
                                         width:520px; border:1px solid #ccc;
                                         background:#fff; padding:8px; z-index:999;">

                                        <!-- Close -->
                                        <span class="close-transfer-btn" style="position:absolute; top:3px; right:5px;
                                              cursor:pointer; font-size:18px; font-weight:bold;">
                                            &#215;
                                        </span>

                                        <!-- Table -->
                                        <table class="table table-bordered table-sm mb-0 transfer-table">
                                            <thead>
                                                <tr>
                                                    <th>Currency</th>
                                                    <th>Counts</th>
                                                    <th>Sub Total</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="rec.line_ids" t-as="line">
                                                    <tr>
                                                        <td>
                                                            <t t-esc="line.currency"/>
                                                        </td>
                                                        <td class="text-center">
                                                            <t t-esc="line.counts"/>
                                                        </td>
                                                        <td class="text-right">
                                                            <t t-esc="line.sub_total"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>

                                    </div>
                                </td>
                            </tr>

                            <t t-set="sl" t-value="sl + 1"/>
                        </t>

                        <tr t-if="not records">
                            <td colspan="9" class="text-center text-danger">
                                No transfer records found.
                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>

        </t>
    </template>
</odoo>
