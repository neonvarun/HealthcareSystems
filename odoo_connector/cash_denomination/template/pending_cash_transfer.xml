<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="pending_cash_transfer_page" name="Pending Cash Transfer">
        <t t-call="website.layout">
            <div class="pending_cash_transfer_template">

                <h2 class="mb-4 text-center fw-bold" style="margin-top:10px;">
                    Pending Cash Transfer
                </h2>

                <div class="container mt-4 mb-5">
                    <div class="row mb-4 justify-content-center">
                        <div class="mb-3 d-flex align-items-center" style="margin-left:15px;">
                            <label for="all_counter" class="form-label me-2 mb-0" style="min-width:90px;">Select Counter</label>
                            <select id="all_counter" name="all_counter" class="form-select" style="width:250px;" required="required">

                                <option value="" disabled="disabled" selected="selected">
                                    Select Counter
                                </option>

                                <t t-foreach="counters" t-as="counter">
                                    <option t-att-value="counter.id">
                                        <t t-esc="counter.bill_counter"/>
                                    </option>
                                </t>

                            </select>

                        </div>
                    </div>

                    <div class="card shadow p-4">
                        <h3 class="mb-4 text-center">Pending Cash</h3>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <strong>Date:</strong>
                                <span id="ct_date"></span>
                            </div>
                            <div class="col-md-4">
                                <strong>From User:</strong>
                                <span id="ct_from_user"></span>
                            </div>
                            <div class="col-md-4">
                                <strong>Transfer Number:</strong>
                                <span id="ct_number" t-att-value="ct_number"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <strong>From Counter:</strong>
                                <span id="ct_from_counter"></span>
                            </div>
                            <div class="col-md-4">
                                <strong>To Counter:</strong>
                                <span id="ct_to_counter"></span>
                            </div>
                        </div>


                        <!-- Cash Denomination Section -->
                        <h5 class="mt-4 mb-3">Cash Denomination</h5>

                        <table class="table table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Currency</th>
                                    <th>Denomination</th>
                                    <th>Count</th>
                                    <th>Sub Total</th>
                                </tr>
                            </thead>
                            <tbody id="denomination_tbody"/>
                            <tfoot>
                                <tr>
                                    <th colspan="3" class="text-end">Total</th>
                                    <th id="denomination_total"></th>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="d-flex justify-content-end mt-4">
                            <button type="button" class="btn btn-success approve-btn me-2">
                            Accept
                            </button>

                            <button type="button" class="btn btn-danger reject-btn">
                            Reject
                            </button>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="rejectReasonModal" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">

                            <div class="modal-header ">
                                <h4 class="modal-title text-center">Reject Cash Transfer</h4>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"/>
                            </div>

                            <div class="modal-body">
                                <label class="form-label">Reason</label>
                                <textarea class="form-control reject-reason" rows="4" placeholder="Enter rejection reason..."/>
                            </div>
                            <div class="modal-footer d-flex justify-content-center">

                                <button type="button" class="btn btn-danger submit-reject-btn">
                                Submit
                                </button>
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                Cancel
                                </button>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </t>
    </template>
</odoo>
