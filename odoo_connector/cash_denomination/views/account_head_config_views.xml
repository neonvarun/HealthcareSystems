<odoo>
    <record id="view_account_head_config_form" model="ir.ui.view">
        <field name="name">account.head.config.form</field>
        <field name="model">account.head.config</field>
        <field name="arch" type="xml">
            <form string="Account Head Configuration">
                <sheet>
                    <group colspan="3">
                        <field name="debit_account_id"/>
                        <field name="credit_account_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_account_head_config_list" model="ir.ui.view">
        <field name="name">account.head.config.list</field>
        <field name="model">account.head.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="debit_account_id"/>
                <field name="credit_account_id"/>
            </list>
        </field>
    </record>

    <record id="action_account_head_config" model="ir.actions.act_window">
        <field name="name">Account Head Setup</field>
        <field name="res_model">account.head.config</field>
        <field name="view_mode">list,form</field>
    </record>


    <menuitem id="menu_account_head_config"
              name="Account Head Config"
              parent="care_connector.menu_main_cash_denomination"
              action="action_account_head_config"
              sequence="4"/>
</odoo>
