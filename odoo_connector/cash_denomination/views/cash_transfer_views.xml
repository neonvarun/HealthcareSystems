<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Cash Transfer List View -->
    <record id="view_cash_transfer_list" model="ir.ui.view">
        <field name="name">cash.transfer.list</field>
        <field name="model">cash.transfer</field>
        <field name="arch" type="xml">
            <list string="Cash Transfers" 
                decoration-warning="status == 'pending'" 
                decoration-success="status == 'accepted'"
                decoration-danger="status == 'rejected'">
                <field name="from_user_name"/>
                <field name="from_counter_name"/>
                <field name="to_user_name"/>
                <field name="to_counter_name"/>
                <field name="amount"/>
                <field name="status" widget="badge" 
                    decoration-warning="status == 'pending'"
                    decoration-success="status == 'accepted'"
                    decoration-danger="status == 'rejected'"/>
                <field name="created_by_name"/>
                <field name="created_at"/>
                <field name="resolved_at" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Cash Transfer Form View -->
    <record id="view_cash_transfer_form" model="ir.ui.view">
        <field name="name">cash.transfer.form</field>
        <field name="model">cash.transfer</field>
        <field name="arch" type="xml">
            <form string="Cash Transfer">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="pending,accepted,rejected"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_journal_entry" type="object" 
                            class="oe_stat_button" icon="fa-book"
                            invisible="not journal_entry_id">
                            <span>Journal Entry</span>
                        </button>
                    </div>
                    <group>
                        <group string="From">
                            <field name="from_session_id" readonly="1"/>
                            <field name="from_user_name" readonly="1"/>
                            <field name="from_counter_name" readonly="1"/>
                        </group>
                        <group string="To">
                            <field name="to_session_id" readonly="1"/>
                            <field name="to_user_name" readonly="1"/>
                            <field name="to_counter_name" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Transfer Details">
                            <field name="amount" readonly="1"/>
                            <field name="denominations" readonly="1" widget="json"/>
                        </group>
                        <group string="Created By">
                            <field name="created_by_name" readonly="1"/>
                            <field name="created_by_ext_id" readonly="1"/>
                            <field name="created_at" readonly="1"/>
                        </group>
                    </group>
                    <group string="Resolution" invisible="status == 'pending'">
                        <group>
                            <field name="resolved_by_name" readonly="1"/>
                            <field name="resolved_by_ext_id" readonly="1"/>
                            <field name="resolved_at" readonly="1"/>
                        </group>
                        <group invisible="status != 'rejected'">
                            <field name="reject_reason" readonly="1"/>
                        </group>
                    </group>
                    <group invisible="not journal_entry_id">
                        <field name="journal_entry_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Cash Transfer Search View -->
    <record id="view_cash_transfer_search" model="ir.ui.view">
        <field name="name">cash.transfer.search</field>
        <field name="model">cash.transfer</field>
        <field name="arch" type="xml">
            <search>
                <field name="amount"/>
            </search>
        </field>
    </record>

    <!-- Cash Transfer Action (All) -->
    <record id="action_cash_transfer_list" model="ir.actions.act_window">
        <field name="name">Cash Transfers</field>
        <field name="res_model">cash.transfer</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cash_transfer_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No cash transfers found
            </p>
            <p>
                Cash transfers are created when cash is moved between sessions.
            </p>
        </field>
    </record>

    <!-- Pending Transfers Action (for Main Cash acceptance) -->
    <record id="action_cash_transfer_pending" model="ir.actions.act_window">
        <field name="name">Pending Transfers</field>
        <field name="res_model">cash.transfer</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status', '=', 'pending')]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No pending transfers
            </p>
            <p>
                Transfers waiting for acceptance will appear here.
            </p>
        </field>
    </record>
</odoo>
