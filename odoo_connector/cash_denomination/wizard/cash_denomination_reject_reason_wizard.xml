<odoo>
    <record id="view_cash_denomination_reject_wizard" model="ir.ui.view">
        <field name="name">cash.denomination.reject.wizard.form</field>
        <field name="model">cash.denomination.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Reason">
                <sheet>
                    <group>
                        <field name="reject_reason" placeholder="Enter rejection reason..." />
                    </group>
                </sheet>
                <footer>
                    <button string="Reject" type="object" name="action_confirm_reject" class="btn btn-danger"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cash_denomination_reject_wizard" model="ir.actions.act_window">
        <field name="name">Reject Reason</field>
        <field name="res_model">cash.denomination.reject.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
