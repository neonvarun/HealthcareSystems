<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_cash_voucher_move_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="page pv-page">
                        <style>
                            .pv-page {
                                font-family: "Times New Roman", serif;
                                font-size: 13px;
                                line-height: 1.3;
                                padding: 18px;
                            }
                            .pv-header {
                                border-bottom: 1px solid #222;
                                padding-bottom: 8px;
                                margin-bottom: 10px;
                            }
                            .pv-company-name {
                                font-size: 20px;
                                font-weight: 700;
                                text-transform: uppercase;
                            }
                            .pv-company-address {
                                font-size: 12px;
                                margin-top: 2px;
                            }
                            .pv-title-row {
                                margin-top: 8px;
                                display: table;
                                width: 100%;
                            }
                            .pv-title-left,
                            .pv-title-right {
                                display: table-cell;
                                vertical-align: top;
                            }
                            .pv-title-left {
                                font-size: 16px;
                                font-weight: 700;
                            }
                            .pv-title-right {
                                width: 280px;
                            }
                            .pv-meta {
                                width: 100%;
                                border-collapse: collapse;
                                font-size: 13px;
                            }
                            .pv-meta td {
                                padding: 1px 0;
                            }
                            .pv-label {
                                font-weight: 700;
                                width: 115px;
                            }
                            .pv-info {
                                border: 1px solid #222;
                                border-collapse: collapse;
                                width: 100%;
                                margin-top: 10px;
                                font-size: 13px;
                            }
                            .pv-info td,
                            .pv-info th {
                                border: 1px solid #222;
                                padding: 6px;
                                vertical-align: top;
                            }
                            .pv-info th {
                                text-align: center;
                                font-size: 14px;
                                font-weight: 700;
                            }
                            .pv-lines td {
                                min-height: 90px;
                            }
                            .pv-right {
                                text-align: right;
                            }
                            .pv-amount {
                                text-align: right;
                                white-space: nowrap;
                                font-weight: 700;
                            }
                            .pv-total-row td {
                                font-weight: 700;
                                font-size: 14px;
                            }
                            .pv-signatures {
                                width: 100%;
                                margin-top: 36px;
                                border-collapse: collapse;
                            }
                            .pv-signatures td {
                                width: 33%;
                                text-align: center;
                                font-size: 13px;
                                padding-top: 52px;
                                border-top: 1px solid #555;
                            }
                        </style>

                        <div class="pv-header">
                            <div class="pv-company-name">
                                <t t-esc="o.company_id.name"/>
                            </div>
                            <div class="pv-company-address">
                                <t t-esc="', '.join(filter(None, [o.company_id.partner_id.street, o.company_id.partner_id.street2, o.company_id.partner_id.city, o.company_id.partner_id.state_id.name if o.company_id.partner_id.state_id else '', o.company_id.partner_id.zip]))"/>
                            </div>
                            <t t-if="o.company_id.vat">
                                <div class="pv-company-address">
                                    GSTIN: <t t-esc="o.company_id.vat"/>
                                </div>
                            </t>
                        </div>

                        <div class="pv-title-row">
                            <div class="pv-title-left">
                                <t t-if="o.move_type == 'out_invoice'"><t t-esc="(o.journal_id.type or 'payment').upper()"/> RECEIPT VOUCHER</t>
                                <t t-elif="o.move_type == 'in_invoice'"><t t-esc="(o.journal_id.type or 'payment').upper()"/> PAYMENT VOUCHER</t>
                                <t t-elif="o.move_type == 'out_refund'"><t t-esc="(o.journal_id.type or 'payment').upper()"/> REFUND VOUCHER</t>
                                <t t-elif="o.move_type == 'in_refund'"><t t-esc="(o.journal_id.type or 'payment').upper()"/> RECEIPT VOUCHER</t>
                                <t t-else=""><t t-esc="(o.journal_id.type or 'payment').upper()"/> VOUCHER</t>
                            </div>
                            <div class="pv-title-right">
                                <table class="pv-meta">
                                    <tr>
                                        <td class="pv-label">Voucher No</td>
                                        <td>: <t t-esc="o.name"/></td>
                                    </tr>
                                    <tr>
                                        <td class="pv-label">Date</td>
                                        <td>: <t t-esc="o.date" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/></td>
                                    </tr>
                                    <tr>
                                        <td class="pv-label"><t t-esc="(o.journal_id.type or 'Payment').capitalize()"/> A/c</td>
                                        <td>: <t t-esc="o.journal_id.name"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <table class="pv-meta" style="margin-top: 8px;">
                            <tr>
                                <td class="pv-label">
                                    <t t-if="o.move_type in ('out_invoice', 'in_refund')">Received From</t>
                                    <t t-elif="o.move_type in ('in_invoice', 'out_refund')">Paid To</t>
                                    <t t-else="">Party</t>
                                </td>
                                <t t-set="party"
                                    t-value="o.partner_id
                                                or (o.line_ids and o.line_ids.filtered(lambda l: l.partner_id) and o.line_ids.filtered(lambda l: l.partner_id)[0].partner_id)
                                            "/>
                                    <td>: <t t-if="party" t-esc="party.name"/><t t-else="">-</t></td>
                            </tr>
                        </table>

                        <table class="pv-info">
                            <tr>
                                <th style="width: 30%;">Account</th>
                                <th style="width: 42%;">Memo / Particulars</th>
                                <th style="width: 28%;">Amount</th>
                            </tr>
                            <tr class="pv-lines">
                                <td><t t-esc="o.partner_id.name or '-'"/></td>
                                <td>
                                    <t t-set="particulars" t-value="o.ref or o.narration or ''"/>
                                    <t t-if="not particulars and o.invoice_line_ids">
                                        <t t-set="line_names" t-value="[l.name for l in o.invoice_line_ids[:3] if l.name and l.display_type not in ('line_section', 'line_note')]"/>
                                        <t t-set="particulars" t-value="', '.join(line_names) + ('...' if len(o.invoice_line_ids) > 3 else '')"/>
                                    </t>
                                    <t t-set="particulars" t-value="', '.join(dict.fromkeys([p.strip() for p in particulars.split(',') if p and p.strip()]))"/>
                                    <t t-esc="particulars or '-'"/>
                                </td>
                                <td class="pv-amount">
                                    INR <span t-esc="'{:,.2f}'.format(o.amount_total)"/>
                                </td>
                            </tr>
                            <tr class="pv-total-row">
                                <td>
                                    <t t-esc="o.currency_id.amount_to_text(o.amount_total)"/> ONLY
                                </td>
                                <td class="pv-right">Total</td>
                                <td class="pv-amount">
                                    INR <span t-esc="'{:,.2f}'.format(o.amount_total)"/>
                                </td>
                            </tr>
                        </table>

                        <table class="pv-signatures">
                            <tr>
                                <td>Prepared By</td>
                                <td>Authorised Signatory</td>
                                <td>
                                    <t t-if="o.move_type in ('out_invoice', 'in_refund')">Receiver's Signature</t>
                                    <t t-else="">Payee's Signature</t>
                                </td>
                            </tr>
                        </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
