<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cash Voucher Report Action for account.payment -->
    <record id="action_report_cash_voucher_payment" model="ir.actions.report">
        <field name="name">Print Cash Voucher</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cash_voucher.report_cash_voucher_template</field>
        <field name="report_file">cash_voucher.report_cash_voucher_template</field>
        <field name="binding_model_id" ref="account.model_account_payment"/>
        <field name="print_report_name">'Cash Voucher - %s' % (object.name)</field>
    </record>

    <!-- Cash Voucher Report Action for account.move -->
    <record id="action_report_cash_voucher_move" model="ir.actions.report">
        <field name="name">Print Cash Voucher</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cash_voucher.report_cash_voucher_move_template</field>
        <field name="report_file">cash_voucher.report_cash_voucher_move_template</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="print_report_name">'Cash Voucher - %s' % (object.name)</field>
    </record>
</odoo>
