<odoo>
    <record id="customer_insurance_list" model="ir.ui.view">
        <field name="name">customer.insurance.list</field>
        <field name="model">customer.insurance</field>
        <field name="arch" type="xml">
            <list>
                <field name="customer_id"/>
                <field name="insurance_tag"/>
                <field name="insurance_company_id"/>
            </list>
        </field>
    </record>

    <record id="customer_insurance_form" model="ir.ui.view">
        <field name="name">customer.insurance.form</field>
        <field name="model">customer.insurance</field>
        <field name="arch" type="xml">
            <form>

                <header>
                    <button name="action_fetch_invoice_lines" type="object" string="Fetch Invoice Lines" invisible="state !='draft'" class="oe_highlight"/>

                    <button name="action_reject" string="Reject" type="object" invisible="state !='confirmed'" class="btn-secondary"/>

                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state not in ('rejected')" class="btn-secondary"/>

                    <button name="action_confirm" string="Confirm" type="object" invisible="state !='draft'" class="oe_highlight"/>

                    <button name="action_approve" string="Approve" type="object" invisible="state !='confirmed'" class="oe_highlight"/>

                    <button name="action_reconcile" string="Reconcile" type="object" invisible="state !='approved'" class="oe_highlight"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,approved,reconciled"/>

                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices" type="object" invisible="invoice_count==0" class="oe_stat_button" icon="fa-pencil-square-o">
                            <div class="o_stat_info">
                                <field name="invoice_count" class="o_stat_value"/>
                                <span class="o_stat_text">Invoices</span>
                            </div>
                        </button>

                        <button name="action_view_journal_entry" type="object" class="oe_stat_button" icon="fa-book" invisible="journal_entry_id==False">

                            <field name="journal_entry_id" widget="statinfo" string="Journal Entry"/>
                        </button>

                    </div>
                    <group>

                        <group>
                            <field name="customer_id" readonly="state != 'draft'"/>
                            <field name="age" readonly="state != 'draft'"/>
                            <field name="doctor" readonly="state != 'draft'"/>
                            <field name="bill_number" readonly="state != 'draft'"/>
                            <field name="ip_number" readonly="state != 'draft'"/>
                            <field name="op_number" readonly="state != 'draft'"/>
                            <field name="room_number" readonly="state != 'draft'"/>
                            <field name="approved_amount" readonly="state != 'draft'"/>
                        </group>

                        <group>
                            <field name="journal_id" readonly="state != 'draft'"/>
                            <field name="journal_ref" readonly="state != 'draft'"/>
                            <field name="insurance_tag" readonly="1"/>
                            <field name="insurance_company_id" readonly="state != 'draft'"/>
                            <field name="approved_date" readonly="state != 'draft'"/>
                            <field name="admission_date" readonly="state != 'draft'"/>
                            <field name="as_on" readonly="state != 'draft'"/>
                            <field name="rejection_reason" invisible="not rejection_reason" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Invoice Lines" readonly="state != 'draft'">
                            <field name="invoice_line_ids">
                                <list editable="bottom">
                                    <field name="description"/>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal" readonly="1"/>
                                    <field name="insurance_amount"/>
                                    <field name="show_in_report"/>
                                </list>
                            </field>

                            <group col="12">
                                <group colspan="8">
                                    <field name="narration" placeholder="Comments" nolabel="1"/>
                                </group>
                                <group colspan="4">
                                    <group class="oe_subtotal_footer">

                                        <field name="total_insured_amount"/>
                                        <field name="total_amount"/>
                                    </group>

                                </group>
                            </group>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="customer_insurance_action" model="ir.actions.act_window">
        <field name="name">Customer Insurance</field>
        <field name="res_model">customer.insurance</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_customer_insurance" name="Customer Insurance" parent="menu_insurance_root" action="customer_insurance_action"/>
</odoo>
