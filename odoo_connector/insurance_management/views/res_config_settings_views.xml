<odoo>
    <record id="res_config_settings_view_form_insurance" model="ir.ui.view">
        <field name="name">res.config.settings.insurance</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//block[@name='main_currency_setting_container']" position="after">
                <block title="Insurance" id="insurance_tag" groups="base.group_system">
                    <setting string="Insurance Settings" id="insurance_settings" company_dependent="1"
                             title="Add Insurance Tag.">
                            <group>
                                <field name="insurance_tag_setting"/>
                            </group>

                    </setting>
                </block>
            </xpath>



        </field>
    </record>
</odoo>
