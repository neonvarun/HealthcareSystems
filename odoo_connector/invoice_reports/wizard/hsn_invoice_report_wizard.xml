<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="hsn_summary_wizard_form_view" model="ir.ui.view">
        <field name="name">HSN Summary Sheet Wizard Form</field>
        <field name="model">invoice.hsn.excel.wizard</field>
        <field name="arch" type="xml">
            <form string="HSN Summary Sheet">
                <sheet>
                    <group>
                        <group string="Company &amp; Period">
                            <field name="company_id" options="{'no_create': True, 'no_open': True}" groups="base.group_multi_company"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group string="Transaction Filter">
                            <field name="move_type"/>
                            <field name="journal_ids" widget="many2many_tags"
                                   domain="[('company_id', '=', company_id), ('type', 'in', ['sale', 'purchase'])]"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <group string="GST Rate Filter">
                            <field name="available_rate_ids" invisible="1"/>
                            <field name="gst_rate_id"
                                   domain="[('company_id', '=', company_id)]"
                                   options="{'no_create': True, 'no_open': True}"
                                   placeholder="All Rates"/>
                        </group>
                        <group string="Report Options">
                            <field name="group_by" widget="radio"/>
                            <field name="include_zero_qty"/>
                        </group>
                    </group>
                    <separator/>
                    <div class="alert alert-info" role="alert">
                        <p class="mb-1"><strong>Report Columns:</strong></p>
                        <p class="mb-0 small">
                            Sr. No | HSN | Description | UQC | Rate | Total Qty | Total Value |
                            Taxable Value | IGST Amount | CGST Amount | SGST/UTGST Amount | Cess Amount
                        </p>
                    </div>
                </sheet>
                <footer>
                    <button name="action_print_excel" string="Download Excel" type="object"
                            class="btn-primary" icon="fa-download"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hsn_summary_wizard" model="ir.actions.act_window">
        <field name="name">HSN Summary Sheet</field>
        <field name="res_model">invoice.hsn.excel.wizard</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="hsn_summary_wizard_form_view"/>
        <field name="target">new</field>
    </record>

    <!-- Parent menu for all invoice excel reports -->
    <menuitem id="menu_nvoice_report_menu"
              name="Invoice Excel Reports"
              sequence="10"
              parent="account.menu_finance_reports"/>

    <!-- HSN Summary menu item -->
    <menuitem id="menu_hsn_invoice_report_menu"
              name="HSN Summary Sheet"
              sequence="1"
              action="action_hsn_summary_wizard"
              parent="menu_nvoice_report_menu"/>

</odoo>
