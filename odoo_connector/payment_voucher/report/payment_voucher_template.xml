<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_payment_custom_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">

                <div class="page" style="font-size:14px; padding-top:5px;">                    

                    <div style="text-align:left; font-weight:bold; font-size:16px;">
                        <t t-esc="o.company_id.name"/>
                    </div>
                    <div style="text-align:left;">
                        <t t-esc="o.company_id.partner_id.contact_address"/>
                    </div>

                    <div style="text-align:left; margin-top:5px; font-size:15px; font-weight:bold;">
                        <t t-if="o.journal_id.type == 'cash'">CASH PAYMENT</t>
                        <t t-elif="o.journal_id.type == 'bank'">BANK PAYMENT</t>
                        <t t-else="">PAYMENT</t>
                        : <t t-esc="o.journal_id.name"/>
                    </div>

                    <table style="width:100%; margin-top:5px;">
                        <tr>
                            <td style="width:70%;"></td>
                            <td style="text-align:right; font-weight:bold;">Voucher No :</td>
                            <td style="width:10%;">
                                <t t-esc="o.name"/>
                            </td>
                        </tr>
                        <tr>
                            <td></td>
                            <td style="text-align:right; font-weight:bold;">Date :</td>
                            <td>
                                <t t-esc="o.date"/>
                            </td>
                        </tr>
                    </table>

                    <strong style="font-size:1.2rem">Payee:</strong>
                    <span style="font-size:1.2rem; margin-left:10px;">
                        <t t-esc="o.payment_method_line_id.name or o.payment_method_id.name or ''"/>
                    </span>
                    <br/>

                    <table border="1" style="width:100%; border-collapse:collapse; margin-top:15px;">

                        <tr style="height:50px; text-align:center; font-weight:bold;">
                            <td style="width:30%;">Account</td>
                            <td style="width:30%;">Memo</td>
                            <td style="width:25%;">Bill No</td>
                            <td style="width:15%;">Amount</td>
                        </tr>

                        <!-- DATA ROW -->
                        <tr style="height:150px;">

                            <!-- PARTNER NAME -->
                            <td style="padding-left:5px;">
                                <t t-esc="o.partner_id.name or ''"/>
                            </td>

                            <!-- MEMO -->
                            <td style="padding-left:5px;">
                                <t t-if="o.memo">
                                    <t t-esc="o.memo"/>
                                </t>
                            </td>

                            <!-- BILL NUMBERS -->
                            <td style="padding-left:5px;">
                                <!-- For outbound payments (vendor bills) -->
                                <t t-if="o.payment_type == 'outbound' and o.reconciled_bill_ids">
                                    <t t-foreach="o.reconciled_bill_ids" t-as="bill">
                                        <t t-esc="bill.name"/><br t-if="not bill_last"/>
                                    </t>
                                </t>
                                <!-- For inbound payments (customer invoices) -->
                                <t t-if="o.payment_type == 'inbound' and o.reconciled_invoice_ids">
                                    <t t-foreach="o.reconciled_invoice_ids" t-as="inv">
                                        <t t-esc="inv.name"/><br t-if="not inv_last"/>
                                    </t>
                                </t>
                            </td>

                            <!-- AMOUNT WITH DR/CR -->
                            <td style="padding-left:5px;">

                                <!-- Inbound → Debit (Dr) -->
                                <t t-if="o.payment_type == 'inbound'">
                                    <t t-esc="'%.2f' % o.amount"/>
                                    Dr
                                </t>

                                <!-- Outbound → Credit (Cr) -->
                                <t t-if="o.payment_type == 'outbound'">
                                    <t t-esc="'%.2f' % o.amount"/>
                                    Cr
                                </t>

                            </td>

                        </tr>

                        <tr style="height:70px;">

                            <td style="padding-left:5px; font-weight:bold;">
                                <t t-esc="o.currency_id.amount_to_text(o.amount)"/>
                                    ONLY
                            </td>

                            <td colspan="2" style="text-align:right; padding-right:10px; font-weight:bold;">
                                Total
                            </td>
                            <td style="padding-left:5px; font-weight:bold;">
                                <t t-esc="'%.2f' % o.amount"/>
                            </td>
                        </tr>

                    </table>

                    <!-- SIGNATURE SECTION -->
                    <table style="width:100%; margin-top:40px;">
                        <tr>
                            <td style="text-align:center; width:25%;">Prepared By</td>
                            <td style="text-align:center; width:25%;">Verified By</td>
                            <td style="text-align:center; width:25%;">Authorised Signatory</td>
                            <td style="text-align:center; width:25%;">Signature of Payee</td>
                        </tr>

                        <tr style="height:150px;">
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </table>

                </div>

            </t>
        </t>
    </template>

</odoo>
