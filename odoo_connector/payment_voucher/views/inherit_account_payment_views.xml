<?xml version="1.0" encoding="utf-8"?>
<odoo>

     <record id="account.action_report_payment_receipt" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
    </record>

     <record id="action_report_custom_receipt" model="ir.actions.report">
        <field name="name"> Print Payment Voucher</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">payment_voucher.report_payment_custom_receipt</field>
        <field name="report_file">payment_voucher.report_payment_custom_receipt</field>
        <field name="binding_model_id" ref="account.model_account_payment"/>
       
        <field name="print_report_name">'Payment Receipt - %s' % (object.name)</field>
        
    </record>
    
</odoo>