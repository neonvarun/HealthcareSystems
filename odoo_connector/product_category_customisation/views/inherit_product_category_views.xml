<odoo>
    <data>

        <record id="view_product_category_form_inherit_taxes" model="ir.ui.view">
            <field name="name">product.category.form.taxes</field>
            <field name="model">product.category</field>
            <field name="inherit_id" ref="product.product_category_form_view"/>

            <field name="arch" type="xml">
                <xpath expr="//form/sheet" position="inside">
                    <notebook>
                        <page string="Other Info" name="other_info">
                            <group>
                                <group>
                                    <field name="tax_id"/>

                                </group>
                                <group>
                                    <field name="factor"/>
                                </group>
                                <group>
                                    <field name="use_different_taxes"/>

                                </group>

                            </group>

                            <field name="subcategory_tax_config_ids" invisible="use_different_taxes==False">

                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="subcategory_id" required="1"/>
                                    <field name="tax_id" required="1"/>
                                    <field name="factor"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </xpath>
            </field>
        </record>


    </data>
</odoo>
