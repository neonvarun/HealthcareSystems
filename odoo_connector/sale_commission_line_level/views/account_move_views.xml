<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add commission_user_id to invoice line form (in invoice form) -->
    <record id="view_move_form_commission_line_level" model="ir.ui.view">
        <field name="name">account.move.form.commission.line.level</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <!-- Add commission_user_id column to invoice lines -->
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='quantity']" position="after">
                <field name="commission_user_id" 
                       string="Commission To"
                       optional="hide"
                       options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>

    <!-- Add commission_user_id filter and group by in account move lines search -->
    <record id="view_account_move_line_filter_commission" model="ir.ui.view">
        <field name="name">account.move.line.filter.commission</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_account_move_line_filter"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="commission_user_id" string="Commission Salesperson"/>
            </field>
            <filter name="group_by_partner" position="after">
                <filter string="Commission Salesperson" name="group_by_commission_user" 
                        context="{'group_by': 'commission_user_id'}"/>
            </filter>
        </field>
    </record>

</odoo>
