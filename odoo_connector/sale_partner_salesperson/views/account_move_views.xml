<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Override invoice form to allow public users as salesperson -->
    <record id="view_move_form_salesperson" model="ir.ui.view">
        <field name="name">account.move.form.salesperson</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <field name="invoice_user_id" position="attributes">
                <attribute name="domain">[]</attribute>
            </field>
        </field>
    </record>

    <!-- Override invoice search to allow public users as salesperson filter -->
    <record id="view_account_invoice_filter_salesperson" model="ir.ui.view">
        <field name="name">account.invoice.select.salesperson</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <field name="invoice_user_id" position="attributes">
                <attribute name="domain">[]</attribute>
            </field>
        </field>
    </record>
</odoo>
