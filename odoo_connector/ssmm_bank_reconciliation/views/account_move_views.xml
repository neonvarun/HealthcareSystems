<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record model="ir.ui.view" id="view_move_form_reconcile">
        <field name="name">account.move.view.form.inherit.reconcile</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='aml_tab']/field[@name='line_ids']/list/field[@name='credit']" position="after">
                <field name="reconcile_date" readonly="1" force_save="1"/>
            </xpath>
        </field>
    </record>


    <record id="view_account_account_form_inherit_bank_cash" model="ir.ui.view">
        <field name="name">account.account.form.bank.cash</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form"/>
        <field name="arch" type="xml">

            <!-- Add the field in the “Other Info” group -->
            <xpath expr="//field[@name='account_type']" position="after">
                <field name="bank_cash_type" invisible="account_type != 'asset_cash'"/>
            </xpath>

        </field>
    </record>
</odoo>